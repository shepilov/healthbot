BOT_TOKEN=123456:replace-with-your-telegram-bot-token
BOT_MODE=long-polling
LOG_LEVEL=info

# Webhook deployment settings. Required only when BOT_MODE=webhook.
WEBHOOK_URL=https://example.com/telegram/webhook
WEBHOOK_SECRET=replace-with-random-secret-token
HOST=0.0.0.0
PORT=3000
HEALTHCHECK_PATH=/health
